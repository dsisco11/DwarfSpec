{
  "schema": "dwarfspec.exit-code-map.v1",
  "mappings": [
    {
      "kind": "success",
      "exit_code": 0,
      "states": ["passed"]
    },
    {
      "kind": "usage",
      "exit_code": 2,
      "states": ["usage_error"]
    },
    {
      "kind": "dependency",
      "exit_code": 3,
      "states": ["dependency_error"]
    },
    {
      "kind": "connection",
      "exit_code": 4,
      "states": ["connection_error"]
    },
    {
      "kind": "registration",
      "exit_code": 5,
      "states": ["registration_error"]
    },
    {
      "kind": "executor_quarantined",
      "exit_code": 5,
      "states": ["executor_quarantined"]
    },
    {
      "kind": "host",
      "exit_code": 5,
      "states": ["host_error"]
    },
    {
      "kind": "test",
      "exit_code": 6,
      "states": ["failed"]
    },
    {
      "kind": "timeout",
      "exit_code": 7,
      "states": ["timeout"]
    },
    {
      "kind": "queue_timeout",
      "exit_code": 7,
      "states": ["queue_timeout"]
    },
    {
      "kind": "aborted",
      "exit_code": 8,
      "states": ["aborted", "interrupted"]
    },
    {
      "kind": "cancelled",
      "exit_code": 8,
      "states": ["cancelled"]
    }
  ]
}
